<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.AmeZakatInvestment" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand colors -->
        <item name="colorPrimary">@color/midnight_blue</item>
        <item name="colorPrimaryVariant">@color/midnight_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/rich_gold</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/midnight_blue</item>
        <!-- Background color -->
        <item name="android:windowBackground">@color/light_orange</item>
        <!-- Custom Action Bar -->
        <item name="actionBarStyle">@style/Widget.AmeZakatInvestment.ActionBar</item>
    </style>

    <style name="Widget.AmeZakatInvestment.ActionBar" parent="Widget.AppCompat.ActionBar">
        <item name="background">@color/midnight_blue</item>
        <item name="titleTextColor">@color/rich_gold</item>
    </style>
</resources>